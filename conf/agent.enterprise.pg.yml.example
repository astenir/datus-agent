# Enterprise PostgreSQL metadata configuration overlay.
#
# Copy the relevant sections into agent.yml for production-like enterprise
# deployments. This file only moves enterprise platform metadata stores to
# PostgreSQL; normal business datasource, model, RAG/vector, and project
# subject/ or artifact bundle files remain in the regular agent.yml/runtime
# paths.
#
# Each PG metadata/body store owns one asyncpg pool. With the eight metadata
# stores below plus the optional session_body_store and max_size=2, each API
# process can open up to 18 enterprise PostgreSQL connections before accounting
# for business datasources or operational clients. Adjust these pool sizes
# together with uvicorn worker/pod count and PostgreSQL max_connections.

api:
  auth_provider:
    # Use this provider when the enterprise gateway cannot inject signed
    # identity headers. Datus validates the bearer token by calling userinfo.
    class: datus_enterprise.auth_provider:UserInfoBearerAuthProvider
    kwargs:
      userinfo_url: ${DATUS_ENTERPRISE_USERINFO_URL}
      timeout_seconds: 3.0
      user_id_field: username
      external_user_id_field: userId
      email_field: email
      display_name_field: realname
      status_field: userStatus
      allowed_statuses: ["正常"]
      default_project_id: enterprise

    # If the enterprise gateway can be changed, prefer signed headers instead:
    #
    # class: datus_enterprise.auth_provider:SignedHeaderAuthProvider
    # kwargs:
    #   secret_env: DATUS_ENTERPRISE_HEADER_SECRET
    #   default_project_id: enterprise

enterprise:
  enabled: true

  authorization_provider:
    class: datus.api.enterprise.defaults:LocalAuthorizationProvider

  config_projector:
    class: datus_enterprise.projection:DatasourceGrantProjector

  user_store:
    class: datus_enterprise.postgres_stores:PgEnterpriseUserStore
    kwargs:
      dsn: ${DATUS_ENTERPRISE_PG_DSN}
      min_size: 1
      max_size: 2

  role_store:
    class: datus_enterprise.postgres_stores:PgEnterpriseRoleStore
    kwargs:
      dsn: ${DATUS_ENTERPRISE_PG_DSN}
      min_size: 1
      max_size: 2

  datasource_grant_store:
    class: datus_enterprise.postgres_stores:PgEnterpriseDatasourceGrantStore
    kwargs:
      dsn: ${DATUS_ENTERPRISE_PG_DSN}
      min_size: 1
      max_size: 2

  session_owner_store:
    class: datus_enterprise.postgres_stores:PgSessionOwnerStore
    kwargs:
      dsn: ${DATUS_ENTERPRISE_PG_DSN}
      min_size: 1
      max_size: 2

  # Optional but recommended for enterprise multi-worker deployments. This
  # moves chat session body/history/state out of local AdvancedSQLiteSession
  # .db files and into PostgreSQL. It is separate from session_owner_store:
  # session_owner_store is the authorization/index metadata table, while this
  # store persists messages/items, message structure, turn usage, running usage,
  # and system-prompt snapshots for new sessions. It does not migrate old .db
  # files automatically.
  session_body_store:
    class: datus_enterprise.postgres_session_store:PgSessionBodyStore
    kwargs:
      dsn: ${DATUS_ENTERPRISE_PG_DSN}
      min_size: 1
      max_size: 2

  artifact_acl_store:
    class: datus_enterprise.postgres_stores:PgArtifactAclStore
    kwargs:
      dsn: ${DATUS_ENTERPRISE_PG_DSN}
      min_size: 1
      max_size: 2

  audit_sink:
    class: datus_enterprise.postgres_stores:PgAuditSink
    kwargs:
      dsn: ${DATUS_ENTERPRISE_PG_DSN}
      min_size: 1
      max_size: 2

  quota_store:
    class: datus_enterprise.postgres_stores:PgEnterpriseQuotaStore
    kwargs:
      dsn: ${DATUS_ENTERPRISE_PG_DSN}
      min_size: 1
      max_size: 2

  secret_store:
    class: datus_enterprise.postgres_stores:PgEnterpriseSecretStore
    kwargs:
      dsn: ${DATUS_ENTERPRISE_PG_DSN}
      min_size: 1
      max_size: 2

# Optional SQL policy. Configure a concrete provider when datasource grants
# must be enforced by SQL rewrite/deny logic in addition to route projection.
#
# agent:
#   sql_policy:
#     enabled: true
#     provider: your_package.sql_policy:YourSqlPolicyProvider
